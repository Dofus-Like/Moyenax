# Backend
DATABASE_URL="postgresql://game_user:game_password@localhost:5432/game_db"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-this-secret-in-production-minimum-32-chars"
JWT_EXPIRES_IN="7d"
PORT=3000
FRONTEND_URL="http://localhost:5173"
ENABLE_DEBUG_ROUTES=false
ENABLE_SWAGGER=false
PERF_LOGS=false
PERF_LOG_SLOW_MS=100
PERF_LOG_SAMPLE_RATE=1

# Frontend
VITE_API_URL="/api/v1"

# Nx Configuration
# NX_TERMINAL_OUTPUT_FORMAT: plain (statique), dynamic (animé), stream-without-prefixes (brut)
NX_TERMINAL_OUTPUT_FORMAT=plain
# NX_TUI: false (désactivé), true (activé)
NX_TUI=false

# Perf HUD / debug endpoints (back + front). 1/true/on = enabled, 0/empty = disabled.
SHOW_DEBUG=1
VITE_SHOW_DEBUG=1
