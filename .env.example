# Backend
DATABASE_URL="postgresql://game_user:game_password@localhost:5432/game_db"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-this-secret-in-production-minimum-32-chars"
JWT_EXPIRES_IN="7d"
PORT=3000
FRONTEND_URL="http://localhost:5173"
SKIP_AUTH=true

# Frontend
VITE_API_URL="/api/v1"

# Nx Configuration
# NX_TERMINAL_OUTPUT_FORMAT: plain (statique), dynamic (animé), stream-without-prefixes (brut)
NX_TERMINAL_OUTPUT_FORMAT=plain
# NX_TUI: false (désactivé), true (activé)
NX_TUI=false
