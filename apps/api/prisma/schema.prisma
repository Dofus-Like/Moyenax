generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemType {
  WEAPON
  ARMOR_HEAD
  ARMOR_CHEST
  ARMOR_LEGS
  ACCESSORY
  CONSUMABLE
  RESOURCE
}

enum EquipmentSlotType {
  WEAPON_LEFT
  WEAPON_RIGHT
  ARMOR_HEAD
  ARMOR_CHEST
  ARMOR_LEGS
  ACCESSORY
}

enum SpellType {
  DAMAGE
  HEAL
  BUFF
}

enum SpellVisualType {
  PHYSICAL
  PROJECTILE
  UTILITY
}

enum SessionStatus {
  WAITING
  ACTIVE
  FINISHED
}

enum GamePhase {
  FARMING
  FIGHTING
}

model Player {
  id           String          @id @default(uuid())
  username     String          @unique
  email        String          @unique
  passwordHash String
  gold         Int             @default(100)
  skin         String          @default("soldier-classic")
  stats        PlayerStats?
  inventory    InventoryItem[]
  spells           PlayerSpell[]
  equipmentSlots   EquipmentSlot[]
  combatsAsP1      CombatSession[] @relation("Player1")
  combatsAsP2      CombatSession[] @relation("Player2")
  gameSessionsAsP1 GameSession[]   @relation("GSP1")
  gameSessionsAsP2 GameSession[]   @relation("GSP2")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model PlayerStats {
  id       String @id @default(uuid())
  playerId String @unique
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  
  // Statistiques effectives (Base + Equipement)
  // Statistiques effectives (Base + Equipement)
  vit      Int    @default(100)
  atk      Int    @default(10)
  mag      Int    @default(10)
  def      Int    @default(5)
  res      Int    @default(5)
  ini      Int    @default(100)
  pa       Int    @default(6)
  pm       Int    @default(3)

  // Statistiques de base (Immuables par l'équipement)
  baseVit  Int    @default(100)
  baseAtk  Int    @default(10)
  baseMag  Int    @default(10)
  baseDef  Int    @default(5)
  baseRes  Int    @default(5)
  baseIni  Int    @default(100)
  basePa   Int    @default(6)
  basePm   Int    @default(3)
}


model Item {
  id           String          @id @default(uuid())
  name         String          @unique
  description  String?
  type         ItemType
  family       String?
  rank         Int             @default(1)
  statsBonus   Json?
  grantsSpells Json?
  craftCost    Json?
  shopPrice    Int?
  inventory    InventoryItem[]
  sessionItems SessionItem[]
}


model InventoryItem {
  id            String         @id @default(uuid())
  playerId      String
  itemId        String
  quantity      Int            @default(1)
  rank          Int            @default(1)
  player        Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  item          Item           @relation(fields: [itemId], references: [id])
  equipmentSlot EquipmentSlot?

  @@unique([playerId, itemId, rank])
}

model EquipmentSlot {
  id              String            @id @default(uuid())
  playerId        String
  slot            EquipmentSlotType
  inventoryItemId String?           @unique
  player          Player            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem?    @relation(fields: [inventoryItemId], references: [id])

  @@unique([playerId, slot])
}

model Spell {
  id        String        @id @default(uuid())
  name      String        @unique
  paCost    Int           @default(3)
  minRange  Int           @default(1)
  maxRange  Int           @default(3)
  damageMin Int           @default(10)
  damageMax Int           @default(20)
  cooldown   Int             @default(0)
  type       SpellType       @default(DAMAGE)
  visualType SpellVisualType @default(PHYSICAL)
  players    PlayerSpell[]
}

model PlayerSpell {
  playerId String
  spellId  String
  level    Int    @default(1)
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  spell    Spell  @relation(fields: [spellId], references: [id])

  @@id([playerId, spellId])
}

model CombatSession {
  id        String        @id @default(uuid())
  status    SessionStatus @default(WAITING)
  player1Id     String
  player2Id     String?
  gameSessionId String?
  winnerId      String?
  player1     Player        @relation("Player1", fields: [player1Id], references: [id])
  player2     Player?       @relation("Player2", fields: [player2Id], references: [id])
  gameSession GameSession?  @relation(fields: [gameSessionId], references: [id])
  turns       CombatTurn[]
  createdAt DateTime      @default(now())
  endedAt   DateTime?
}

model CombatTurn {
  id         String        @id @default(uuid())
  sessionId  String
  session    CombatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  turnNumber Int
  playerId   String
  actions    Json
  createdAt  DateTime      @default(now())
}

model GameSession {
  id           String          @id @default(uuid())
  status       SessionStatus   @default(WAITING)
  phase        GamePhase       @default(FARMING)
  currentRound Int             @default(1)
  player1Wins  Int             @default(0)
  player2Wins  Int             @default(0)
  player1Ready Boolean         @default(false)
  player2Ready Boolean         @default(false)
  gold         Int             @default(500) // Augmenté pour le start
  player1Id    String
  player2Id    String?
  p1           Player          @relation("GSP1", fields: [player1Id], references: [id])
  p2           Player?         @relation("GSP2", fields: [player2Id], references: [id])
  inventory    SessionItem[]
  combats      CombatSession[]
  createdAt    DateTime        @default(now())
  endedAt      DateTime?
}

model SessionItem {
  id        String      @id @default(uuid())
  sessionId String
  playerId  String
  itemId    String
  quantity  Int         @default(1)
  equipped  Boolean     @default(false)
  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  item      Item        @relation(fields: [itemId], references: [id])

  @@unique([sessionId, playerId, itemId])
}
