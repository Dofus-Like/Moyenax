generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemType {
  WEAPON
  ARMOR_HEAD
  ARMOR_CHEST
  ARMOR_LEGS
  ACCESSORY
  CONSUMABLE
  RESOURCE
}

enum EquipmentSlotType {
  WEAPON_LEFT
  WEAPON_RIGHT
  ARMOR_HEAD
  ARMOR_CHEST
  ARMOR_LEGS
  ACCESSORY
}

enum SpellType {
  DAMAGE
  HEAL
  BUFF
}

enum SpellVisualType {
  PHYSICAL
  PROJECTILE
  UTILITY
}

enum SessionStatus {
  WAITING
  ACTIVE
  FINISHED
}

model Player {
  id           String          @id @default(uuid())
  username     String          @unique
  email        String          @unique
  passwordHash String
  gold         Int             @default(100)
  stats        PlayerStats?
  inventory    InventoryItem[]
  spells       PlayerSpell[]
  equipmentSlots EquipmentSlot[]
  combatsAsP1  CombatSession[] @relation("Player1")
  combatsAsP2  CombatSession[] @relation("Player2")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model PlayerStats {
  id       String @id @default(uuid())
  playerId String @unique
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  
  // Statistiques effectives (Base + Equipement)
  vit      Int    @default(100)
  atk      Int    @default(5)
  mag      Int    @default(0)
  def      Int    @default(0)
  res      Int    @default(0)
  ini      Int    @default(10)
  pa       Int    @default(6)
  pm       Int    @default(3)

  // Statistiques de base (Immuables par l'équipement)
  baseVit  Int    @default(100)
  baseAtk  Int    @default(5)
  baseMag  Int    @default(0)
  baseDef  Int    @default(0)
  baseRes  Int    @default(0)
  baseIni  Int    @default(10)
  basePa   Int    @default(6)
  basePm   Int    @default(3)
}


model Item {
  id           String          @id @default(uuid())
  name         String          @unique
  description  String?         // Une description "goofy"
  type         ItemType
  family       String?         // FORGE, ARCANE, NATURE, SPECIAL
  rank         Int             @default(1)
  statsBonus   Json?
  grantsSpells Json?           
  craftCost    Json?
  shopPrice    Int?
  inventory    InventoryItem[]
}


model InventoryItem {
  id            String         @id @default(uuid())
  playerId      String
  itemId        String
  quantity      Int            @default(1)
  rank          Int            @default(1)
  player        Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  item          Item           @relation(fields: [itemId], references: [id])
  equipmentSlot EquipmentSlot?

  @@unique([playerId, itemId, rank])
}

model EquipmentSlot {
  id              String            @id @default(uuid())
  playerId        String
  slot            EquipmentSlotType
  inventoryItemId String?           @unique
  player          Player            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem?    @relation(fields: [inventoryItemId], references: [id])

  @@unique([playerId, slot])
}

model Spell {
  id        String        @id @default(uuid())
  name      String        @unique
  paCost    Int           @default(3)
  minRange  Int           @default(1)
  maxRange  Int           @default(3)
  damageMin Int           @default(10)
  damageMax Int           @default(20)
  cooldown   Int             @default(0)
  type       SpellType       @default(DAMAGE)
  visualType SpellVisualType @default(PHYSICAL)
  players    PlayerSpell[]
}

model PlayerSpell {
  playerId String
  spellId  String
  level    Int    @default(1)
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  spell    Spell  @relation(fields: [spellId], references: [id])

  @@id([playerId, spellId])
}

model CombatSession {
  id        String        @id @default(uuid())
  status    SessionStatus @default(WAITING)
  player1Id String
  player2Id String?
  winnerId  String?
  player1   Player        @relation("Player1", fields: [player1Id], references: [id])
  player2   Player?       @relation("Player2", fields: [player2Id], references: [id])
  turns     CombatTurn[]
  createdAt DateTime      @default(now())
  endedAt   DateTime?
}

model CombatTurn {
  id         String        @id @default(uuid())
  sessionId  String
  session    CombatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  turnNumber Int
  playerId   String
  actions    Json
  createdAt  DateTime      @default(now())
}
