datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ItemType {
  WEAPON
  ARMOR
  RING
  CONSUMABLE
  RESOURCE
}

enum SpellType {
  DAMAGE
  HEAL
  BUFF
}

enum SessionStatus {
  WAITING
  ACTIVE
  FINISHED
}

model Player {
  id           String          @id @default(uuid())
  username     String          @unique
  email        String          @unique
  passwordHash String
  gold         Int             @default(100)
  stats        PlayerStats?
  inventory    InventoryItem[]
  spells       PlayerSpell[]
  combatsAsP1  CombatSession[] @relation("Player1")
  combatsAsP2  CombatSession[] @relation("Player2")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model PlayerStats {
  id         String @id @default(uuid())
  playerId   String @unique
  player     Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  baseHp     Int    @default(100)
  baseAp     Int    @default(6)
  baseMp     Int    @default(4)
  strength   Int    @default(10)
  agility    Int    @default(10)
  initiative Int    @default(10)
}

model Item {
  id         String          @id @default(uuid())
  name       String          @unique
  type       ItemType
  statsBonus Json?
  craftCost  Json?
  shopPrice  Int?
  inventory  InventoryItem[]
}

model InventoryItem {
  id       String  @id @default(uuid())
  playerId String
  itemId   String
  quantity Int     @default(1)
  equipped Boolean @default(false)
  player   Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  item     Item    @relation(fields: [itemId], references: [id])

  @@unique([playerId, itemId])
}

model Spell {
  id        String        @id @default(uuid())
  name      String        @unique
  apCost    Int
  minRange  Int           @default(1)
  maxRange  Int           @default(3)
  damageMin Int           @default(10)
  damageMax Int           @default(20)
  cooldown  Int           @default(0)
  type      SpellType     @default(DAMAGE)
  players   PlayerSpell[]
}

model PlayerSpell {
  playerId String
  spellId  String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  spell    Spell  @relation(fields: [spellId], references: [id])

  @@id([playerId, spellId])
}

model CombatSession {
  id        String        @id @default(uuid())
  status    SessionStatus @default(WAITING)
  player1Id String
  player2Id String
  winnerId  String?
  player1   Player        @relation("Player1", fields: [player1Id], references: [id])
  player2   Player        @relation("Player2", fields: [player2Id], references: [id])
  turns     CombatTurn[]
  createdAt DateTime      @default(now())
  endedAt   DateTime?
}

model CombatTurn {
  id         String        @id @default(uuid())
  sessionId  String
  session    CombatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  turnNumber Int
  playerId   String
  actions    Json
  createdAt  DateTime      @default(now())
}
