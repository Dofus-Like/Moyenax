{
  "name": "@game-monorepo/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev:api": "dotenv -e .env -- nx serve api",
    "dev:web": "dotenv -e .env -- nx serve web",
    "dev": "dotenv -e .env -- nx run-many --target=serve --projects=api,web --parallel",
    "perf:api:start": "PERF_API_PORT=3100 PERF_PROD_PORT=3101 dotenv -e .env -- node scripts/perf/start.mjs",
    "perf:api:baseline": "PERF_API_PORT=3100 PERF_PROD_PORT=3101 dotenv -e .env -- node scripts/perf/baseline.mjs",
    "perf:api:prod-start": "PERF_API_PORT=3100 PERF_PROD_PORT=3101 dotenv -e .env -- node scripts/perf/prod-start.mjs",
    "perf:api:report": "PERF_API_PORT=3100 PERF_PROD_PORT=3101 dotenv -e .env -- node scripts/perf/report.mjs",
    "perf:api:compare": "PERF_API_PORT=3100 PERF_PROD_PORT=3101 dotenv -e .env -- node scripts/perf/compare.mjs",
    "build": "dotenv -e .env -- nx run-many --target=build --all",
    "test": "dotenv -e .env -- nx run-many --target=test --all",
    "lint": "dotenv -e .env -- nx run-many --target=lint --all",
    "db:migrate": "prisma migrate dev --schema=apps/api/prisma/schema.prisma",
    "db:migrate:deploy": "dotenv -e .env -- prisma migrate deploy --schema=apps/api/prisma/schema.prisma",
    "db:generate": "prisma generate --schema=apps/api/prisma/schema.prisma",
    "db:seed": "ts-node apps/api/prisma/seed.ts",
    "db:kill-combats": "dotenv -e .env -- ts-node scripts/dev/kill-active-combats.ts",
    "db:studio": "prisma studio --schema=apps/api/prisma/schema.prisma",
    "docker:dev": "node scripts/dev/container-stack.mjs up",
    "docker:dev:down": "node scripts/dev/container-stack.mjs down",
    "docker:dev:infra": "docker compose up -d",
    "docker:prod": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d",
    "stack:prod-local": "node scripts/ci/prod-local-up.mjs",
    "stack:prod-local:down": "node scripts/ci/prod-local-down.mjs",
    "smoke:prod-local": "node scripts/ci/prod-local-smoke.mjs",
    "repro:matchmaking:legacy-redis": "node scripts/ci/repro-matchmaking-legacy-redis.mjs",
    "ci:prepush": "node scripts/ci/prepush.mjs",
    "setup": "yarn install && yarn docker:dev:infra && yarn db:migrate && yarn db:seed",
    "game:sim": "node scripts/balance_sim.js",
    "clean": "taskkill /F /IM node.exe /T 2>nul & powershell -Command \"Get-NetTCPConnection -LocalPort 3000, 5173 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue }\" 2>nul & exit 0",
    "prepare": "husky",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome format --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0"
    ]
  },
  "private": true,
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "5",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-query": "^5.90.21",
    "@types/supertest": "^7.2.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "leva": "^0.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "supertest": "^7.2.2",
    "swagger-ui-express": "^5.0.1",
    "three": "^0.183.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.14.5",
    "@babel/preset-react": "^7.14.5",
    "@biomejs/biome": "^2.4.13",
    "@darraghor/eslint-plugin-nestjs-typed": "^7.1.30",
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/devkit": "22.5.4",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/jest": "22.5.4",
    "@nx/js": "^22.5.4",
    "@nx/nest": "^22.5.4",
    "@nx/node": "22.5.4",
    "@nx/playwright": "22.5.4",
    "@nx/react": "^22.5.4",
    "@nx/vite": "^22.5.4",
    "@nx/web": "22.5.4",
    "@nx/webpack": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "^0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/stats.js": "^0.17.4",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.0.0",
    "ajv": "^8.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.8.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^16.4.0",
    "nx": "22.5.4",
    "prisma": "5",
    "r3f-perf": "^7.2.3",
    "stats.js": "^0.17.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "~4.5.0",
    "vitest": "^4.0.0",
    "web-vitals": "^5.2.0",
    "webpack-cli": "^5.1.4"
  }
}
